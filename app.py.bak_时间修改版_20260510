def build_parcats(df_base, top_lifts):
    """
    波浪流向图 (go.Sankey):
      - 每列 = 柱状图里一个高 Lift 特征 (列标题显示在顶部)
      - 列内节点 = 该特征的取值 (日期特征已在 extract_time_features 聚合为 "一天一类")
      - 节点标签: "值 (F:<fail数> P:<pass数>)"
      - 节点颜色: Fail 占比低 → 浅蓝; Fail 占比高 → 粉红 (线性插值)
      - 波浪 = 相邻两列的样本流; 粉 = Fail 流, 蓝 = Pass 流; 宽度 = 样本数
    """
    if not top_lifts or 'Results' not in df_base.columns or len(df_base) == 0:
        return None
    feats = [it['feature'] for it in top_lifts if it['feature'] in df_base.columns]
    if len(feats) < 2:
        return None

    # 列数不设上限 (默认 TOP 20 全部展示), 列宽靠宽度撑开 + 外层横向滚动条
    MAX_VALS_PER_COL = 8
    feats = list(feats)

    work = df_base[feats].astype(str).copy()
    work['_fail'] = (df_base['Results'].astype(str) == 'FAIL').astype(int).values

    # 每列: 低频取值合并为 "其他"
    for feat in feats:
        vc = work[feat].value_counts()
        if len(vc) > MAX_VALS_PER_COL:
            keep = set(vc.head(MAX_VALS_PER_COL).index)
            work[feat] = work[feat].where(work[feat].isin(keep), '其他')

    def _short(name):
        s = (name.replace('VCM_', '')
                 .replace('_MC_ID', '')
                 .replace('_日期', ' 日期')
                 .replace('_', ' '))
        return s if len(s) <= 20 else s[:18] + '…'

    # 构造节点: (feat, val) → node
    node_labels, node_colors, node_x, node_y = [], [], [], []
    node_idx = {}
    n_feats = len(feats)

    for i, feat in enumerate(feats):
        grp = (work.groupby(feat, observed=True)['_fail']
                   .agg(fail='sum', total='count'))
        grp['pass_'] = grp['total'] - grp['fail']
        grp = grp.sort_values('total', ascending=False)
        n_vals = max(len(grp), 1)

        for j, (val, row) in enumerate(grp.iterrows()):
            fail_cnt = int(row['fail'])
            pass_cnt = int(row['pass_'])
            total = int(row['total'])
            fr = fail_cnt / total if total > 0 else 0

            display_val = str(val)
            if len(display_val) > 18:
                display_val = display_val[:16] + '…'

            node_idx[(feat, val)] = len(node_labels)
            node_labels.append(f"{display_val}  F:{fail_cnt}  P:{pass_cnt}")

            # 浅蓝 (144,202,249) → 粉红 (244,143,177)
            r = int(144 + 100 * fr)
            g = int(202 - 59 * fr)
            b = int(249 - 72 * fr)
            node_colors.append(f'rgba({r},{g},{b},0.9)')

            # 显式布局: x 均匀列分布; y 在 [0.08, 0.96] 内均匀铺开
            node_x.append(round(0.02 + i * (0.96 / max(n_feats - 1, 1)), 4))
            node_y.append(round(0.08 + (j + 0.5) * (0.88 / n_vals), 4))

    # 构造 links: 相邻两列之间的 (值1, 值2, Fail) 汇总
    sources, targets, values, link_colors = [], [], [], []
    for i in range(n_feats - 1):
        f1, f2 = feats[i], feats[i + 1]
        g = (work.groupby([f1, f2, '_fail'], observed=True)
                  .size().reset_index(name='_n'))
        for _, r in g.iterrows():
            sources.append(node_idx[(f1, r[f1])])
            targets.append(node_idx[(f2, r[f2])])
            values.append(int(r['_n']))
            link_colors.append('rgba(244,143,177,0.55)' if r['_fail']
                               else 'rgba(144,202,249,0.28)')

    # 列标题: 顶部列名 annotations (相当于 Sankey 的 x 轴刻度)
    col_title_anns = [dict(
        x=0.02 + i * (0.96 / max(n_feats - 1, 1)),
        y=1.035, xref='paper', yref='paper', xanchor='center',
        showarrow=False,
        font=dict(size=14, color='#111',
                  family='Inter, "Microsoft YaHei", sans-serif'),
        text=f"<b>{_short(feat)}</b>",
    ) for i, feat in enumerate(feats)]

    legend_ann = dict(
        x=0.5, y=1.09, xref='paper', yref='paper', xanchor='center',
        showarrow=False, font=dict(size=14, color='#444'),
        text=('节点色: <span style="color:#90caf9">■</span> 低 Fail率 ｜ '
              '<span style="color:#f48fb1">■</span> 高 Fail率 　　 '
              '波浪: <span style="color:#f48fb1">━</span> Fail 流 ｜ '
              '<span style="color:#90caf9">━</span> Pass 流'),
    )

    fig = go.Figure(go.Sankey(
        arrangement='snap',
        node=dict(
            pad=32, thickness=18,
            line=dict(width=0),
            label=node_labels,
            color=node_colors,
            x=node_x, y=node_y,
            hovertemplate='%{label}<extra></extra>',
        ),
        link=dict(
            source=sources, target=targets, value=values,
            color=link_colors, line=dict(width=0),
            hovertemplate=('%{source.label} → %{target.label}<br>'
                           '样本数: %{value}<extra></extra>'),
        ),
        textfont=dict(family='Inter, "Microsoft YaHei", sans-serif',
                      size=14, color='#1a1a1a'),
    ))

    # 宽度随列数撑开 (外层 <div overflow-x:auto> 负责出现滚动条)
    max_vals = max(1, max(work[f].nunique() for f in feats))
    chart_width = max(1600, 360 * n_feats + 160)
    fig.update_layout(
        width=chart_width,
        height=max(720, 95 * max_vals + 320),
        margin=dict(l=30, r=30, t=120, b=40),
        paper_bgcolor='white',
        plot_bgcolor='white',
        font=dict(family='Inter, "Microsoft YaHei", sans-serif',
                  size=14, color='#222'),
        annotations=col_title_anns + [legend_ann],
    )
    return fig


